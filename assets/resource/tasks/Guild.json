{
    "task": [
        {
            "name": "公会",
            "label":"$公会",
            "entry": "guild_entry",
            "description":"公会：请确保已加入公会",
            "icon":null,
            "default_check": true,
            "option": [
                "公会升级",
                "公会扭蛋",
                "公会奖牌交换所"
            ],
            "repeatable": false,
            "repeat_count": 1
        }
    ],
    "option": {
        "公会升级": {
            "type":"switch",
            "label":"$是否启用公会升级",
            "description":"自动提交蓝色焰火",
            "icon":null,
            "default_case":"yes",
            "cases": [
                {
                    "name": "yes",
                    "pipeline_override": {
                        "guild_upgrade_entry": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "no",
                    "pipeline_override": {
                        "guild_upgrade_entry": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "公会扭蛋": {
            "type":"switch",
            "label":"$是否启用公会扭蛋",
            "description":"自动进行公会扭蛋",
            "icon":null,
            "default_case":"yes",
            "cases": [
                {
                    "name": "yes",
                    "pipeline_override": {
                        "guild_gacha": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "no",
                    "pipeline_override": {
                        "guild_gacha": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "公会奖牌交换所":{
            "type":"switch",
            "label":"$公会奖牌交换所",
            "description":"是否启用公会奖牌交换所",
            "icon":null,
            "default_case":"no",
            "cases": [
                {
                    "name": "yes",
                    "pipeline_override": {
                        "guild_shop_entry": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "no",
                    "pipeline_override": {
                        "guild_shop_entry": {
                            "enabled": false
                        }
                    }
                }
            ]
        }
    }
}